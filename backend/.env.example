# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/location_tracker

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# Auth0 API audience used to validate access tokens
OAUTH_AUDIENCE=https://location-tracker-api

# Legacy JWT secret fallback (optional if you are using Auth0)
JWT_SECRET=change-this-to-a-random-secret

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# OAuth/OIDC Configuration (from Auth0)
OAUTH_CLIENT_ID=YOUR_AUTH0_CLIENT_ID
OAUTH_CLIENT_SECRET=YOUR_AUTH0_CLIENT_SECRET
OAUTH_ISSUER=https://YOUR_AUTH0_DOMAIN.auth0.com