# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/location_tracker

# Kafka Configuration
KAFKA_BROKERS=localhost:9092

# Auth0 API audience used to validate access tokens
OAUTH_AUDIENCE=https://location-tracker-api

# Legacy JWT secret fallback (optional if you are using Auth0)
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# OAuth/OIDC Configuration (from Keycloak)
OAUTH_CLIENT_ID=location-tracker-api
OAUTH_CLIENT_SECRET=location-tracker-api-secret
OAUTH_ISSUER=http://localhost:8081/realms/location-tracker